{
  "name": "@fastyoke/sdk",
  "version": "0.1.3",
  "description": "Public SDK for FastYoke extensions — typed API clients, React primitives, and the extension loader contract.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "keywords": [
    "fastyoke",
    "extension",
    "sdk",
    "fsm",
    "logistics",
    "apaas"
  ],
  "homepage": "https://github.com/versacomp/fastyoke-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/versacomp/fastyoke-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/versacomp/fastyoke-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
