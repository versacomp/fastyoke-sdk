{
  "name": "hello-fastyoke",
  "version": "0.1.0",
  "private": true,
  "description": "Reference FastYoke extension — proves the runtime load path.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=esm --target=es2020 --jsx=automatic --outfile=dist/bundle.mjs --external:react --external:react/jsx-runtime --external:@fastyoke/sdk"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "@fastyoke/sdk": "^0.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
